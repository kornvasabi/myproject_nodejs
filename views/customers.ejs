<%- include('layouts/header') %>
<%- include('layouts/sidebar') %>
<%- include('layouts/topbar') %>

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800"><i class="fas fa-users"></i> ข้อมูลลูกค้า</h1>
        <button class="btn btn-primary shadow-sm" id="btnAddCustomer">
            <i class="fas fa-plus fa-sm text-white-50"></i> เพิ่มลูกค้าใหม่
        </button>
    </div>

    <div class="d-none d-lg-block">
        <div class="card shadow mb-4 border-left-primary">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="customerTable" width="100%" cellspacing="0">
                        <thead class="bg-light text-center">
                            <tr>
                                <th>รหัส</th>
                                <th>สาขา</th>
                                <th>ชื่อ-นามสกุล</th>
                                <th>ประเภท</th>
                                <th>เบอร์โทรศัพท์</th>
                                <th>ธนาคาร</th>
                                <th>จัดการ</th>
                            </tr>
                        </thead>
                        <tbody id="customerTableBody">
                            </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="d-block d-lg-none">
        <h6 class="font-weight-bold text-primary mb-3"><i class="fas fa-list"></i> รายชื่อลูกค้าทั้งหมด</h6>
        <div class="row" id="customerListMobile">
            </div>
    </div>
</div>

<div class="modal fade" id="customerModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-gradient-primary text-white">
                <h5 class="modal-title font-weight-bold" id="modalTitle">เพิ่มลูกค้าใหม่</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form id="customerForm">
                <div class="modal-body p-4">
                    <input type="hidden" id="customerId" name="id"> 
                    
                    <div class="row">
                        <div class="col-md-12 form-group">
                            <label>สาขาประจำ <span class="text-danger">*</span></label>
                            <select class="form-control" id="formBranchId" name="branch_id" required 
                                <%= typeof accessLevel !== 'undefined' && accessLevel === 3 ? 'readonly style="pointer-events: none; background-color: #eaecf4;"' : '' %>>
                                
                                <% if (typeof accessLevel !== 'undefined' && accessLevel !== 3) { %>
                                    <option value="">-- เลือกสาขา --</option>
                                <% } %>

                                <% if (typeof branches !== 'undefined') { %>
                                    <% branches.forEach(function(b) { %>
                                        <option value="<%= b.id %>" <%= typeof accessLevel !== 'undefined' && accessLevel === 3 ? 'selected' : '' %> >
                                            <%= b.branch_name %>
                                        </option>
                                    <% }); %>
                                <% } %>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>ชื่อ-นามสกุล <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="customerName" name="customer_name" required>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label>ประเภทลูกค้า</label>
                            <select class="form-control" id="customerType" name="customer_type">
                                <option value="walk_in">ขาจร (Walk-in)</option>
                                <option value="regular">ประจำ (Regular)</option>
                            </select>
                        </div>
                        <div class="col-md-6 form-group">
                            <label>เบอร์โทรศัพท์</label>
                            <input type="text" class="form-control" id="phoneNumber" name="phone_number">
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label>ชื่อธนาคาร</label>
                            <select class="form-control" id="bankName" name="bank_name">
                                <option value="">-- ไม่ระบุ --</option>
                                <option value="KBANK">กสิกรไทย (KBANK)</option>
                                <option value="SCB">ไทยพาณิชย์ (SCB)</option>
                                <option value="BBL">กรุงเทพ (BBL)</option>
                                <option value="KTB">กรุงไทย (KTB)</option>
                                <option value="BAAC">ธ.ก.ส. (BAAC)</option>
                            </select>
                        </div>
                        <div class="col-md-6 form-group">
                            <label>เลขที่บัญชี</label>
                            <input type="text" class="form-control" id="bankAccountNo" name="bank_account_no">
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">ยกเลิก</button>
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> บันทึกข้อมูล</button>
                </div>
            </form>
        </div>
    </div>
</div>

<%- include('layouts/footer') %>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
$(document).ready(function() {
    // 🚀 1. ฟังก์ชันโหลดข้อมูลลูกค้าลงตาราง และ การ์ดมือถือ
    function loadCustomers() {
        $.get('<%= baseUrl %>/api/customers', function(response) {
            if (response.status === 'success') {
                let rows = '';
                let mobileCards = ''; // 🟢 ตัวแปรเก็บ HTML สำหรับมือถือ

                response.data.forEach(c => {
                    let typeBadge = c.customer_type === 'regular' 
                        ? '<span class="badge badge-success">ลูกค้าประจำ</span>' 
                        : '<span class="badge badge-secondary">ขาจร</span>';
                    
                    let customerData = encodeURIComponent(JSON.stringify(c));

                    // =====================================
                    // 💻 สำหรับ Desktop (Table)
                    // =====================================
                    rows += `
                        <tr>
                            <td class="text-center font-weight-bold text-primary">${c.customer_code}</td>
                            <td class="text-center"><span class="badge badge-info">${c.branch_name || '-'}</span></td>
                            <td>${c.customer_name}</td>
                            <td class="text-center">${typeBadge}</td>
                            <td class="text-center">${c.phone_number || '-'}</td>
                            <td class="text-center">${c.bank_name || '-'} <br> <small class="text-muted">${c.bank_account_no || ''}</small></td>
                            <td class="text-center" style="white-space: nowrap;">
                                <button class="btn btn-sm btn-info btn-edit" data-info="${customerData}"><i class="fas fa-edit"></i></button>
                                <button class="btn btn-sm btn-danger btn-delete" data-id="${c.id}" data-name="${c.customer_name}"><i class="fas fa-trash"></i></button>
                            </td>
                        </tr>
                    `;

                    // =====================================
                    // 📱 สำหรับ Mobile (Cards)
                    // =====================================
                    mobileCards += `
                        <div class="col-12 mb-3">
                            <div class="card border-left-primary shadow-sm h-100">
                                <div class="card-body py-3">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="font-weight-bold text-primary"><i class="fas fa-id-badge"></i> ${c.customer_code}</span>
                                        <span class="badge badge-info">${c.branch_name || '-'}</span>
                                    </div>
                                    <h6 class="font-weight-bold text-dark mb-2">${c.customer_name}</h6>
                                    
                                    <div class="text-sm text-muted mb-3">
                                        <div class="mb-1"><strong>ประเภท:</strong> ${typeBadge}</div>
                                        <div class="mb-1"><i class="fas fa-phone fa-fw"></i> ${c.phone_number || 'ไม่ระบุ'}</div>
                                        <div><i class="fas fa-university fa-fw"></i> ${c.bank_name || 'ไม่ระบุ'} <small>${c.bank_account_no || ''}</small></div>
                                    </div>
                                    
                                    <div class="text-right border-top pt-2 mt-2">
                                        <button class="btn btn-sm btn-outline-info btn-edit" data-info="${customerData}">
                                            <i class="fas fa-edit"></i> แก้ไข
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger btn-delete" data-id="${c.id}" data-name="${c.customer_name}">
                                            <i class="fas fa-trash"></i> ลบ
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `;
                });
                
                // อัปเดตตาราง Desktop
                if ($.fn.DataTable.isDataTable('#customerTable')) {
                    $('#customerTable').DataTable().clear().destroy();
                }
                $('#customerTableBody').html(rows);
                $('#customerTable').DataTable({
                    language: { url: '//cdn.datatables.net/plug-ins/1.13.4/i18n/th.json' }
                });

                // 🟢 อัปเดต Card มือถือ
                if (mobileCards === '') {
                    mobileCards = '<div class="col-12 text-center text-muted py-4">ไม่พบข้อมูลลูกค้า</div>';
                }
                $('#customerListMobile').html(mobileCards);
            }
        });
    }

    loadCustomers(); // โหลดข้อมูลทันทีที่เปิดหน้าเว็บ

    // 🚀 2. เปิด Modal สำหรับ "เพิ่มข้อมูล"
    $('#btnAddCustomer').click(function() {
        $('#customerForm')[0].reset();
        $('#customerId').val('');
        $('#modalTitle').text('เพิ่มลูกค้าใหม่');
        $('#customerModal').modal('show');
    });

    // 🚀 3. เปิด Modal สำหรับ "แก้ไขข้อมูล"
    $(document).on('click', '.btn-edit', function() {
        let data = JSON.parse(decodeURIComponent($(this).data('info')));
        
        $('#customerId').val(data.id);
        $('#formBranchId').val(data.branch_id);
        $('#customerName').val(data.customer_name);
        $('#customerType').val(data.customer_type);
        $('#phoneNumber').val(data.phone_number);
        $('#bankName').val(data.bank_name);
        $('#bankAccountNo').val(data.bank_account_no);
        
        $('#modalTitle').text('แก้ไขข้อมูลลูกค้า: ' + data.customer_code);
        $('#customerModal').modal('show');
    });

    // 🚀 4. จัดการฟอร์ม (รองรับทั้งเพิ่มและแก้ไขในตัวเดียว)
    $('#customerForm').submit(function(e) {
        e.preventDefault();
        
        let id = $('#customerId').val();
        let url = id ? '<%= baseUrl %>/api/customers/update/' + id : '<%= baseUrl %>/api/customers/add';
        let formData = $(this).serialize();

        $.post(url, formData, function(response) {
            if(response.status === 'success') {
                Swal.fire({ icon: 'success', title: 'สำเร็จ', text: response.message, showConfirmButton: false, timer: 1500 });
                $('#customerModal').modal('hide');
                loadCustomers(); // โหลดตารางใหม่
            } else {
                Swal.fire('ผิดพลาด', response.message, 'error');
            }
        });
    });

    // 🚀 5. ยกเลิกข้อมูล (Soft Delete)
    $(document).on('click', '.btn-delete', function() {
        let id = $(this).data('id');
        let name = $(this).data('name');

        Swal.fire({
            title: 'ยืนยันการยกเลิก?',
            text: `คุณต้องการยกเลิกลูกค้า "${name}" ใช่หรือไม่? (ข้อมูลบิลเก่าๆ จะยังอยู่)`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'ใช่, ยกเลิกเลย!',
            cancelButtonText: 'ปิด'
        }).then((result) => {
            if (result.isConfirmed) {
                $.post('<%= baseUrl %>/api/customers/delete/' + id, function(response) {
                    if(response.status === 'success') {
                        Swal.fire('ยกเลิกสำเร็จ!', response.message, 'success');
                        loadCustomers(); // โหลดตารางใหม่
                    }
                });
            }
        });
    });
});
</script>