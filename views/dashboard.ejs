<%- include('./layouts/header') %>
<%- include('./layouts/sidebar') %>

<div id="content-wrapper" class="d-flex flex-column">
    <div id="content">

        <%- include('./layouts/topbar') %>

        <div class="container-fluid">

            <div class="d-sm-flex align-items-center justify-content-between mb-4">
                <h1 class="h3 mb-0 text-gray-800">Dashboard</h1>
                <a href="#" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
                    <i class="fas fa-download fa-sm text-white-50"></i> ออกรายงานสรุป
                </a>
            </div>

            <div class="alert alert-success shadow-sm mb-4" role="alert">
                <h4 class="alert-heading"><i class="fas fa-smile-beam"></i> ยินดีต้อนรับเข้าสู่ระบบครับ!</h4>
                <p>สวัสดีคุณ <strong><%= session.user ? session.user.fullname : 'ผู้ใช้งาน' %></strong> วันนี้มีภารกิจอะไรให้ระบบจัดการ สั่งการผ่านเมนูด้านซ้ายมือได้เลยครับ!</p>
                <hr>
                <p class="mb-0 text-sm">💡 <em>สิทธิ์การใช้งานของคุณคือ: ระดับผู้ดูแลระบบ <%= session.user ? session.user.group_name : 'User' %></em></p>
            </div>

            <div class="row">
                <div class="col-xl-3 col-md-6 mb-4">
                    <div class="card border-left-primary shadow h-100 py-2">
                        <div class="card-body">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">ผู้ใช้งานในระบบ</div>
                                    <div class="h5 mb-0 font-weight-bold text-gray-800">150 <span class="text-sm font-weight-normal text-muted">คน</span></div>
                                </div>
                                <div class="col-auto">
                                    <i class="fas fa-users fa-2x text-gray-300"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-3 col-md-6 mb-4">
                    <div class="card border-left-success shadow h-100 py-2">
                        <div class="card-body">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-success text-uppercase mb-1">สาขาทั้งหมด</div>
                                    <div class="h5 mb-0 font-weight-bold text-gray-800">12 <span class="text-sm font-weight-normal text-muted">สาขา</span></div>
                                </div>
                                <div class="col-auto">
                                    <i class="fas fa-store fa-2x text-gray-300"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-3 col-md-6 mb-4">
                    <div class="card border-left-info shadow h-100 py-2">
                        <div class="card-body">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-info text-uppercase mb-1">แผนกที่ใช้งาน</div>
                                    <div class="h5 mb-0 font-weight-bold text-gray-800">8 <span class="text-sm font-weight-normal text-muted">แผนก</span></div>
                                </div>
                                <div class="col-auto">
                                    <i class="fas fa-sitemap fa-2x text-gray-300"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-3 col-md-6 mb-4">
                    <div class="card border-left-warning shadow h-100 py-2">
                        <div class="card-body">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">รอการตรวจสอบ</div>
                                    <div class="h5 mb-0 font-weight-bold text-gray-800">5 <span class="text-sm font-weight-normal text-muted">รายการ</span></div>
                                </div>
                                <div class="col-auto">
                                    <i class="fas fa-bell fa-2x text-gray-300"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-lg-8 mb-4">
                    <div class="card shadow mb-4 h-100">
                        <div class="card-header py-3">
                            <h6 class="m-0 font-weight-bold text-primary">สถิติการเข้าใช้งานระบบ (จำลอง)</h6>
                        </div>
                        <div class="card-body d-flex align-items-center justify-content-center bg-light">
                            <div class="text-center text-muted">
                                <i class="fas fa-chart-area fa-3x mb-3"></i>
                                <p>พื้นที่สำหรับแสดงกราฟสถิติ</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 mb-4">
                    <div class="card shadow mb-4 h-100">
                        <div class="card-header py-3">
                            <h6 class="m-0 font-weight-bold text-primary">เมนูด่วน (Quick Links)</h6>
                        </div>
                        <div class="card-body">
                            <a href="/myproject_nodejs/user_list" class="btn btn-primary btn-block text-left mb-2">
                                <i class="fas fa-user-cog mr-2"></i> จัดการผู้ใช้งาน
                            </a>
                            <a href="#" class="btn btn-success btn-block text-left mb-2">
                                <i class="fas fa-store mr-2"></i> จัดการสาขา
                            </a>
                            <a href="#" class="btn btn-info btn-block text-left mb-2">
                                <i class="fas fa-sitemap mr-2"></i> จัดการแผนก
                            </a>
                            <hr>
                            <div class="text-center text-sm text-muted mt-3">
                                <i class="fas fa-server"></i> สถานะเซิร์ฟเวอร์: <span class="text-success">ปกติ</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
        </div>
</div>
<%- include('./layouts/footer') %>