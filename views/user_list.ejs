<%- include('./layouts/header') %>

<%- include('./layouts/sidebar') %>

<div id="content-wrapper" class="d-flex flex-column">
    <div id="content">

        <%- include('./layouts/topbar') %>

        <div class="container-fluid">

            <h1 class="h3 mb-4 text-gray-800">ตั้งค่ากลุ่มผู้ใช้</h1>
            
            <div class="card shadow mb-4">
                <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 font-weight-bold text-primary">รายชื่อกลุ่มผู้ใช้ในระบบ</h6>
                    <button class="btn btn-sm btn-success shadow-sm" onclick="AppTools.showModal('เพิ่มกลุ่มผู้ใช้', 'กำลังพัฒนาฟอร์มเพิ่มข้อมูล...', 'info')">
                        <i class="fas fa-plus fa-sm text-white-50"></i> เพิ่มกลุ่มใหม่
                    </button>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover" id="userGroupTable" width="100%" cellspacing="0">
                            <thead class="thead-light">
                                <tr>
                                    <th width="15%" class="text-center">รหัสกลุ่ม (ID)</th>
                                    <th>ชื่อกลุ่มการใช้งาน</th>
                                    <th width="20%" class="text-center">จัดการ</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="text-center">1</td>
                                    <td>ผู้ดูแลระบบ (Admin)</td>
                                    <td class="text-center">
                                        <button class="btn btn-warning btn-sm" title="แก้ไข"><i class="fas fa-edit"></i></button>
                                        <button class="btn btn-danger btn-sm" title="ลบ"><i class="fas fa-trash"></i></button>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="text-center">2</td>
                                    <td>พนักงานทั่วไป (Staff)</td>
                                    <td class="text-center">
                                        <button class="btn btn-warning btn-sm" title="แก้ไข"><i class="fas fa-edit"></i></button>
                                        <button class="btn btn-danger btn-sm" title="ลบ"><i class="fas fa-trash"></i></button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    </div>
<%- include('./layouts/footer') %>

<script>
    // สั่งให้ตารางกลายเป็น DataTables ภาษาไทยทันที!
    // (ใช้ setTimeout นิดนึงเพื่อรอให้ jQuery ใน footer โหลดเสร็จก่อนครับ)
    document.addEventListener("DOMContentLoaded", function() {
        setTimeout(function() {
            AppTools.initDataTable('#userGroupTable');
        }, 100);
    });
</script>